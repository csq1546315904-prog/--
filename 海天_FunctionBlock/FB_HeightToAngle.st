FUNCTION_BLOCK FB_HeightToAngle
(*
=====================================================
功能块名称：FB_HeightToAngle
功能描述：
    用于将曲柄连杆机构中滑块的直线位移（高度）转换为曲柄转角（角度），
    属于典型的运动学逆解计算。

主要逻辑：
    1. 对输入高度 HeightMM 做输入钳位，限制在 [0, 2*RR] 范围内，
       防止超出机构物理行程。
    2. 以曲柄最低点（180°）为基准，计算滑块相对于曲柄旋转中心的
       绝对位置 xll = HeightMM + y_min。
    3. 利用余弦定理求解曲柄角 θ：
          L² = RR² + xll² - 2·RR·xll·cos(θ)
       推导出 cos(θ) = (xll² + RR² - L²) / (2·RR·xll)。
    4. 对 k = cos(θ) 钳位至 [-1, 1]，防止浮点误差导致 ACOS 越界。
    5. 通过反余弦 ACOS(k) 计算角度并转换为度数输出 AngleDeg。

维护注意：
    - RR 为曲柄半径，L 为连杆长度，修改机构尺寸时需同步更新默认值。
    - 输入高度 0 mm → 180°（下死点），2*RR → 0°（上死点），与
      物理机构对应关系固定，不可随意改动。
    - ACOS 使用 π ≈ 3.14159265359，精度已满足工程需求。
    - Y 变量声明但当前实现未使用，后续可用于扩展中间计算。
    - 修改本功能块时，请在下方"历史修改记录"追加记录。

历史修改记录：
    版本        日期            修改人        修改内容
    V1.0        2026-05-31      Codex         从 AP 工程导出并整理，新增功能描述及维护记录模板
=====================================================
*)
VAR_INPUT
    // 滑块输入高度，单位 mm，物理行程范围 0 ~ 2*RR
    HeightMM            : REAL;
END_VAR

VAR_OUTPUT
    // 曲柄输出角度，单位 °，范围 0 ~ 180（0° 为上死点，180° 为下死点）
    AngleDeg            : REAL;
END_VAR

VAR
    // 曲柄半径，默认 16.0 mm
    RR                  : REAL := 16.0;

    // 连杆长度，默认 220.0 mm
    L                   : REAL := 220.0;

    // 下死点（180°）时滑块相对于曲柄旋转中心的绝对位置
    y_min               : REAL;

    // 预留中间变量，当前实现未使用
    Y                   : REAL;

    // cos(θ) 中间值，用于 ACOS 计算前钳位
    k                   : REAL;

    // 滑块相对于曲柄旋转中心的绝对位置
    xll                 : REAL;
END_VAR


// =====================================================
// 1. 输入钳位：限制在 [0, 2*RR] 行程范围内
// =====================================================
IF HeightMM > 2.0 * RR THEN
    HeightMM := 2.0 * RR;
ELSE
    IF HeightMM < 0.0 THEN
        HeightMM := 0.0;
    END_IF;
END_IF;


// =====================================================
// 2. 基准高度：180° 下死点时滑块相对曲柄中心位置
// =====================================================
y_min := -RR + L;


// =====================================================
// 3. 滑块绝对高度（相对曲柄旋转中心）
// =====================================================
xll := HeightMM + y_min;


// =====================================================
// 4. 余弦定理计算 cos(θ)
//    L² = RR² + xll² - 2·RR·xll·cos(θ)
//    => cos(θ) = (xll² + RR² - L²) / (2·RR·xll)
// =====================================================
k := (xll * xll + RR * RR - L * L) / (2.0 * xll * RR);


// =====================================================
// 5. 钳位 k 至 [-1, 1]，防止浮点误差导致 ACOS 越界
// =====================================================
IF k > 1.0 THEN
    k := 1.0;
ELSIF k < -1.0 THEN
    k := -1.0;
END_IF;


// =====================================================
// 6. 反余弦计算角度并转换为度数
//    0 mm → 180°，32 mm → 0°
// =====================================================
AngleDeg := ACOS(k) * 180.0 / 3.14159265359;
