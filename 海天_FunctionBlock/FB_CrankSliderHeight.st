FUNCTION_BLOCK FB_CrankSliderHeight
(*
=====================================================
功能块名称：FB_CrankSliderHeight
功能描述：
    用于将曲柄转角（角度）转换为曲柄连杆机构中滑块的直线位移
    （高度），属于典型的运动学正解计算。与 FB_HeightToAngle
    互为逆运算。

主要逻辑：
    1. 将输入角度 AngleDeg 由度数转换为弧度 angleRad。
    2. 使用曲柄连杆机构正解公式计算滑块高度：
          HeightMM = RR + RR·cos(θ) + √(L² - (RR·sin(θ))²) - L
       其中 θ = angleRad, RR = 曲柄半径, L = 连杆长度。
    3. 0°（上死点）→ HeightMM = 2·RR = 32 mm，
       180°（下死点）→ HeightMM = 0 mm。

维护注意：
    - RR 为曲柄半径，L 为连杆长度，修改机构尺寸时需同步更新默认值。
    - 输入角度 0° → 32 mm（上死点），180° → 0 mm（下死点），与
      物理机构对应关系固定，不可随意改动。
    - 与 FB_HeightToAngle 互为逆运算，两者 RR、L 默认值必须一致。
    - 修改本功能块时，请在下方"历史修改记录"追加记录。

历史修改记录：
    版本        日期            修改人        修改内容
    V1.0        2026-05-31      Codex         从 AP 工程导出并整理，新增功能描述及维护记录模板
=====================================================
*)
VAR_INPUT
    // 输入曲柄角度，单位 °，范围 0 ~ 180（0° 为上死点，180° 为下死点）
    AngleDeg            : REAL;
END_VAR

VAR_OUTPUT
    // 输出滑块高度，单位 mm，范围 0 ~ 2*RR（即 0 ~ 32 mm）
    HeightMM            : REAL;
END_VAR

VAR
    // 曲柄半径，默认 16.0 mm，需与 FB_HeightToAngle 保持一致
    RR                  : REAL := 16.0;

    // 连杆长度，默认 220.0 mm，需与 FB_HeightToAngle 保持一致
    L                   : REAL := 220.0;

    // 角度弧度值，由度数转换而来
    angleRad            : REAL;
END_VAR


// =====================================================
// 1. 角度转弧度
// =====================================================
angleRad := AngleDeg * 3.14159265359 / 180.0;


// =====================================================
// 2. 曲柄连杆正解：角度 → 滑块高度
//    HeightMM = RR + RR·cos(θ) + √(L² - (RR·sin(θ))²) - L
//    0° → 2·RR = 32 mm（上死点）
//    180° → 0 mm（下死点）
// =====================================================
HeightMM := RR
          + RR * COS(angleRad)
          + SQRT(L * L - (RR * SIN(angleRad)) * (RR * SIN(angleRad)))
          - L;
