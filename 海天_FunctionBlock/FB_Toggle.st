FUNCTION_BLOCK FB_Toggle
(*
=====================================================
功能块名称：FB_Toggle
功能描述：
    带置位/复位优先的按键翻转功能块。Set 优先置位输出，
    Reset 次优先复位输出，在无置位/复位时由 Key 上升沿
    翻转输出状态。

主要逻辑：
    1. Set 优先级最高：Set 为 TRUE 时直接置位 Out := TRUE。
    2. Reset 优先级次之：Reset 为 TRUE 且 Set 为 FALSE 时，
       复位 Out := FALSE。
    3. 无 Set/Reset 时，检测 Key 上升沿（当前 TRUE 且上一
       周期 FALSE），触发 Out 翻转。
    4. 每个周期更新 prevKey，用于下一周期的上升沿检测。

维护注意：
    - Set 优先级 > Reset > Key 翻转，此优先级固定不可更改。
    - Key 上升沿检测依赖 prevKey，首次调用时 prevKey 为 FALSE，
      若 Key 初始为 TRUE 则首个周期会触发一次翻转。
    - 修改本功能块时，请在下方"历史修改记录"追加记录。

历史修改记录：
    版本        日期            修改人        修改内容
    V1.0        2026-05-31      Codex         从 AP 工程导出并整理，新增功能描述及维护记录模板
=====================================================
*)
VAR_INPUT
    // 按键输入：上升沿时翻转输出（仅在 Set 和 Reset 均为 FALSE 时生效）
    Key                 : BOOL;

    // 置位命令：TRUE 时强制输出为 TRUE，优先级最高
    Set                 : BOOL;

    // 复位命令：TRUE 且 Set 为 FALSE 时强制输出为 FALSE
    Reset               : BOOL;
END_VAR

VAR_OUTPUT
    // 输出状态
    Out                 : BOOL;
END_VAR

VAR
    // 上一周期按键状态，用于 Key 上升沿检测
    prevKey             : BOOL;
END_VAR


// =====================================================
// 1. Set 优先级最高：强制置位
// =====================================================
IF Set THEN
    Out := TRUE;

// =====================================================
// 2. Reset 优先级次之：强制复位
// =====================================================
ELSIF Reset THEN
    Out := FALSE;

// =====================================================
// 3. 无 Set/Reset 时，Key 上升沿翻转输出
// =====================================================
ELSE
    IF (Key = TRUE) AND (prevKey = FALSE) THEN
        Out := NOT Out;
    END_IF;
END_IF;


// =====================================================
// 4. 保存本周期 Key 状态，供下一周期上升沿检测
// =====================================================
prevKey := Key;


