            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM prIOsetting_test
VAR
	R_TRIG_0: R_TRIG;
	R_TRIG_1: R_TRIG;
	FB_Toggle_0: FB_Toggle;
	bx: BOOL;
	FB_Toggle_1: FB_Toggle;
	FB_Toggle_2: FB_Toggle;
	FB_Toggle_AF: FB_Toggle;
	mModeSel :WORD;
	bStaticState: BOOL;
END_VAR
</Single>
            <Single Name="LineInfoPersistence" Type="string">572165d0-f46e-4b14-8331-3c8bcaa1e3b2_Decl_LineIds</Single>
          </Single>
