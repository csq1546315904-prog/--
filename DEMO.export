            <Single Name="TextBlobForSerialisation" Type="string">wI0  := %IB0;
wQ20 := %QW10;

iPTE_mm := TO_WORD(Tcp.iPTE_mm *100);
iPOP_mm := TO_WORD(Tcp.iPOP_mm *100);
iPUP_mm := TO_WORD(Tcp.iPUP_mm *100);
iReady_mm := TO_WORD(Tcp.iReady_mm *100);
iDelayTime_ms := TO_WORD(Tcp.iDelayTime_ms);
iPunchSpeed_Max := TO_WORD(Tcp.intermediate_iPunchSpeed_Max*10);
iPSP1_mm := TO_WORD(Tcp.iPSP1_mm *100);
iPunchSpeed := TO_WORD(Tcp.iPunchSpeed *10);
iPSP2_mm := TO_WORD(Tcp.iPSP2_mm *100);
wActPos := DINT_TO_REAL(LREAL_TO_DINT(ActPos * 100)) / 100;
wPunHeight_mm := TO_WORD(PunHeight *100);
wStep := TO_WORD(iStep);

wMode_hmi := wModeSel;
wCommuanomaly.0 := Tcp.bError;

bSetPosExe := wSetPosExe.0;
SetPosValue := INT_TO_LREAL(REAL_TO_INT(wdSetPosValue * 100)) / 100;

FB_CrankSliderHeight_1(AngleDeg:= TO_REAL(ActPos), HeightMM=&gt; PunHeight);

</Single>
