          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_BLINK
VAR_INPUT
	Enable: BOOL;         // 使能信号，TRUE 时启动闪烁
    Period: TIME; // 闪烁周期，如写 1 秒（亮暗各占一半）
END_VAR
VAR_OUTPUT
	Q: BOOL;              // 输出信号，周期性反转
END_VAR
VAR
	Timer: TON;           // 定时器，用于计时
    State: BOOL := FALSE; // 内部状态变量
END_VAR
</Single>
