          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">IF HeightMM&gt;2*RR THEN
	HeightMM :=2*RR;
ELSE
	IF HeightMM&lt;0 THEN
		HeightMM :=0;
	END_IF
END_IF

(* 基准高度：180°最低点 *)
y_min := -RR + L;

(* 滑块绝对高度 *)
xll := HeightMM + y_min;

(* 计算 cos(theta) *)
k := (xll*xll + RR*RR - L*L) / (2.0 * xll * RR);

(* 限制 k 在 -1~1 防止浮点误差 *)
IF k &gt; 1.0 THEN
    k := 1.0;
ELSIF k &lt; -1.0 THEN
    k := -1.0;
END_IF

(* 0 mm 对应 180°，32 mm 对应 0° *)
AngleDeg := ACOS(k) * 180.0 / 3.14159265359;</Single>
