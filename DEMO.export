            <Single Name="TextBlobForSerialisation" Type="string">
angleRad := AngleDeg * 3.14159265359 / 180.0;

HeightMM := RR
          + RR * COS(angleRad)
          + SQRT(L*L - (RR * SIN(angleRad)) * (RR * SIN(angleRad)))
          - L;

</Single>
