          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">(* Auto-Generated Code by 'Modbus Configurator'.
 * DO NOT MODIFY HERE!
 * Changes will be overwritten.
 * If modification is required create a copy of this object. *)

//Slave1 ModbusTCP connect 172.16.10.11
Modbus_TCP_Set1(Execute:= TRUE, Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH, IP:=IP1, 
    Done =&gt;, Socket =&gt;, Error =&gt;, ErrorID =&gt;ModbusTCP_MasterVars.Slave1TCPSetErrorId);

TONList[0](IN:=TRUE, PT:= T#100MS);
TONList[1](IN:=TRUE, PT:= T#100MS);



FOR Cycle := 0 TO 1  DO
  IF NOT DoModbusRWList[NowModbusRWIndex] THEN
    IF TONList[NowModbusRWIndex-0].Q THEN
      TONList[NowModbusRWIndex-0](IN:=FALSE);
      DoModbusRWList[NowModbusRWIndex] := TRUE;
      EXIT;
    ELSE
      NowModbusRWIndex := NowModbusRWIndex + 1;
      NowModbusRWIndex := NowModbusRWIndex MOD 2;
    END_IF
  ELSE
    EXIT;
  END_IF
END_FOR


//Slave1 ModbusTCP Id1 ReadHolding ModbusRead1
IF DoModbusRWList[0] THEN
  ModbusRead1(Execute:= DoModbusRWList[0], Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH, Socket:=Modbus_TCP_Set1.Socket, ID:= 2, 
    AddrType:= COM_LIB.Modbus_READ_REG_TYPE.HoldingReg, Addr:= 0, Num:= 10, 
    TimeOut:= 1000, pByteBuf:= ADR(ModbusTCP_MasterVars.Slave1Id1RBuff), ByteBufSize:= 20,
    Done =&gt;, Busy =&gt;, Error =&gt;, ErrorID =&gt;ModbusTCP_MasterVars.Slave1Id1RErrorId);

  IF ModbusRead1.Done THEN
    Tcp.intermediate_iPOP_mm := ModbusTCP_MasterVars.Slave1Id1RBuff[0];
    Tcp.intermediate_iReady_mm := ModbusTCP_MasterVars.Slave1Id1RBuff[1];
    Tcp.intermediate_iPUP_mm := ModbusTCP_MasterVars.Slave1Id1RBuff[2];
    Tcp.intermediate_iDelayTime_ms := ModbusTCP_MasterVars.Slave1Id1RBuff[3];
    Tcp.intermediate_iPSP2_mm := ModbusTCP_MasterVars.Slave1Id1RBuff[4];
    Tcp.intermediate_iPSP1_mm := ModbusTCP_MasterVars.Slave1Id1RBuff[5];
    Tcp.intermediate_iPunchSpeed := ModbusTCP_MasterVars.Slave1Id1RBuff[6];
    Tcp.intermediate_iPunchSpeed_Max := ModbusTCP_MasterVars.Slave1Id1RBuff[7];

  END_IF

  IF ModbusRead1.Done OR ModbusRead1.Error THEN
    ModbusRead1(Execute:= FALSE);
    DoModbusRWList[0] := FALSE;
    NowModbusRWIndex := NowModbusRWIndex + 1;
    NowModbusRWIndex := NowModbusRWIndex MOD 2;
  END_IF
END_IF

//Slave1 ModbusTCP Id2 WriteMultipleHolding ModbusWrite2
IF DoModbusRWList[1] THEN
  ModbusTCP_MasterVars.Slave1Id2WBuff[6].0 := bIdle;
  ModbusWrite2(Execute:= DoModbusRWList[1], Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH,  Socket:=Modbus_TCP_Set1.Socket, ID:= 2, 
    AddrType:= COM_LIB.Modbus_WRITE_REG_TYPE.MultiRegisters, Addr:= 20, Num:= 10, 
    TimeOut:= 1000, pByteBuf:= ADR(ModbusTCP_MasterVars.Slave1Id2WBuff), ByteBufSize:= 20,
    Done =&gt;, Busy =&gt;, Error =&gt;, ErrorID =&gt;ModbusTCP_MasterVars.Slave1Id2WErrorId);

  IF ModbusWrite2.Done OR ModbusWrite2.Error THEN
    ModbusWrite2(Execute:= FALSE);
    DoModbusRWList[1] := FALSE;
    NowModbusRWIndex := NowModbusRWIndex + 1;
    NowModbusRWIndex := NowModbusRWIndex MOD 2;
  END_IF
END_IF</Single>
