            </Value>
          </Entry>
        </Dictionary>
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">638986231288772427</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">(* 1. 清除所有报警位 *)
FOR i := 0 TO 99 DO
    AlarmBits[i] := FALSE;
END_FOR

(* 2. 判断驱动器报警码 *)
FOR i := 0 TO 36 DO
    IF DrvAlarmCode = DrvAlarmMap[i] THEN
        AlarmBits[i] := TRUE;   (* 比如 i=0 对应 Er034 *)
    END_IF
END_FOR

(* 3. PLC 内部报警 *)
//AlarmBits[40] := TCP.bError;
AlarmBits[41] := PlcAlarm_OverTemp;
AlarmBits[42] := PlcAlarm_EStop;
AlarmBits[51] := bDebug_AFErr;
AlarmBits[52] := bDebug_MoveErr;
AlarmBits[53] := bDebug_SetHomeErr;

(* 4. 写入到 HMI Modbus 地址区 *)
FOR i := 0 TO 99 DO
    IF AlarmBits[i] THEN
        HmiAlarm[i] := 1;
    ELSE
        HmiAlarm[i] := 0;
    END_IF
END_FOR

(* 给数控系统报警 *)
IF DrvAlarmCode&lt;&gt;0 THEN
	bDriveError := TRUE; 		
ELSE	
	bDriveError := FALSE; 		
END_IF
		
</Single>
            <Single Name="LineInfoPersistence" Type="string">85bedbba-062d-4001-80e5-9f2f7c77a97e_Impl_LineIds</Single>
          </Single>
        </Single>
        <Single Name="Interface" Type="{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}" Method="IArchivable">
