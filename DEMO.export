    </Single>
    <Single Type="{6198ad31-4b98-445c-927f-3258a0e82fe3}" Method="IArchivable">
      <Single Name="IsRoot" Type="bool">False</Single>
      <Single Name="MetaObject" Type="{81297157-7ec9-45ce-845e-84cab2b88ade}" Method="IArchivable">
        <Single Name="Guid" Type="System.Guid">7f8dd5f5-7d3a-4fe4-a48d-c23c1bcdaf83</Single>
        <Single Name="ParentGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
        <Single Name="Name" Type="string">prTestFunction</Single>
        <Dictionary Type="{2c41fa04-1834-41c1-816e-303c7aa2c05b}" Name="Properties" />
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">638957086519599922</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">
FB_Toggle_TestOn(Key:= bTest_OnOff , Set:= , Reset:= , Out=&gt; bTest);
FB_Toggle_bTest_iPOP(Key:= bTest_iPOP , Set:= , Reset:= NOT bTest, Out=&gt; bTest_GoPOP);

IF bTest THEN
	Tcp.iPOP_mm :=iTest_Punch_POP_mm;
	FB_HeightToAngle_Pop(HeightMM:= iTest_Punch_POP_mm, AngleDeg=&gt;Tcp.iPOP_deg );
	wModeSel:= iTest_Punch_Mode;
ELSE
	iTest_Step :=0;
	iTest_Counter := iStep_Counter :=0;
END_IF

CASE iTest_Step OF
	0:
//		bTest_iPunch :=bTest_iPOP :=FALSE;
		bTest_iPunch :=FALSE;
		IF bTest AND bTest_GoPOP THEN
			iTest_Step:=10;
		END_IF
	10:
		act_Jump_To_PTE();
		iStep_Counter :=iStep_Counter+1;
		IF iStep_Counter&gt;100 THEN
//			bTest_iPOP :=TRUE;
			iStep_Counter :=0;
			iTest_Step:=20;
		END_IF
	20:
		act_Jump_To_PTE();
		iStep_Counter :=iStep_Counter+1;
		IF iStep_Counter&gt;200 THEN
//			bTest_iPOP :=FALSE;
			iStep_Counter :=0;
			iTest_Step:=30;
		END_IF

	30:	
		act_Jump_To_PTE();
		iStep_Counter :=iStep_Counter+1;
		IF iStep_Counter&gt;200 THEN
			bTest_iPunch :=TRUE;
			iStep_Counter :=0;
			iTest_Step:=40;
		END_IF
		
	40:
		act_Jump_To_PTE();
		iStep_Counter :=iStep_Counter+1;
		IF iStep_Counter&gt;3 THEN
			bTest_iPunch :=FALSE;
			iStep_Counter :=0;
			iTest_Step:=50;
		END_IF
	
	50:
		act_Jump_To_PTE();	
		IF bTest AND qbReadyFeed AND NOT bTest_iPunch THEN	
			iStep_Counter :=iStep_Counter+1;
			IF iStep_Counter&gt;iTest_Punch_Delay THEN
				bTest_iPunch := TRUE;
				iStep_Counter :=0;
				iTest_Step:=40;
			END_IF
		END_IF
	
END_CASE

</Single>
            <Single Name="LineInfoPersistence" Type="string">7f8dd5f5-7d3a-4fe4-a48d-c23c1bcdaf83_Impl_LineIds</Single>
          </Single>
        </Single>
        <Single Name="Interface" Type="{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM prTestFunction
VAR
	FB_Toggle_TestOn :FB_Toggle;
	iTest_Counter :INT;
	iTest_Step :INT;
	iStep_Counter :INT :=0;
	iTest_Punch_Mode AT %MW1601:WORD;
	iTest_Punch_POP_mm AT %MD1602:REAL :=9;
	iTest_Punch_Delay AT %MW1603:INT :=600;
	FB_HeightToAngle_Pop :FB_HeightToAngle;
	FB_Toggle_bTest_iPOP :FB_Toggle;
END_VAR
</Single>
            <Single Name="LineInfoPersistence" Type="string">7f8dd5f5-7d3a-4fe4-a48d-c23c1bcdaf83_Decl_LineIds</Single>
          </Single>
        </Single>
        <Single Name="UniqueIdGenerator" Type="string">114</Single>
        <Single Name="POULevel" Type="{8e575c5b-1d37-49c6-941b-5c0ec7874787}">Standard</Single>
        <List Name="ChildObjectGuids" Type="System.Collections.ArrayList" />
        <Single Name="AddAttributeSubsequent" Type="bool">False</Single>
      </Single>
      <Single Name="ParentSVNodeGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
      <Array Name="Path" Type="string">
        <Single Type="string">Device</Single>
        <Single Type="string">PLC逻辑</Single>
        <Single Type="string">Application</Single>
      </Array>
      <Single Name="Index" Type="int">-1</Single>
    </Single>
    <Single Type="{6198ad31-4b98-445c-927f-3258a0e82fe3}" Method="IArchivable">
      <Single Name="IsRoot" Type="bool">False</Single>
      <Single Name="MetaObject" Type="{81297157-7ec9-45ce-845e-84cab2b88ade}" Method="IArchivable">
        <Single Name="Guid" Type="System.Guid">abe29934-06af-468a-84a4-b760d94de097</Single>
        <Single Name="ParentGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
        <Single Name="Name" Type="string">Punch_PA</Single>
        <Dictionary Type="{2c41fa04-1834-41c1-816e-303c7aa2c05b}" Name="Properties" />
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">638984703223476661</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">IF NOT bAFOn  THEN
	iStep := iCounter:=0;
END_IF 

CASE iStep OF
	0://Power Off, reset data
		AxAbs_0.bExe := AxAbs_1.bExe :=AxAbs_2.bExe := bAF_Off := bReset :=FALSE;
		IF bAFOn AND MC_POWER0.Error THEN
			iCounter :=0;
			iStep :=1;
		END_IF
		IF bAFOn AND NOT MC_POWER0.Error AND AxisVars.Axis0.AxisMotionState.ServoEnabled AND NOT bMode_SetPos THEN
			iStep :=7;
		END_IF
	1:
		bReset := bAF_Off :=TRUE;
		iCounter :=iCounter +1;
		IF iCounter &gt;1000 AND MC_RESET0.Done THEN
			bReset :=FALSE;
			iStep :=2; iCounter :=0;
		END_IF
	2: bReset :=FALSE; bAF_Off :=TRUE;
		iCounter :=iCounter +1;
		IF iCounter &gt;1000 THEN
			bAF_Off :=FALSE;
			iStep :=0; iCounter :=0;//返回0步
		END_IF
		
	7://PrePTE
		act_7_GoPTE();
		AxAbs_0.bExe := AxAbs_1.bExe :=AxAbs_2.bExe :=FALSE;
		iCounter:= iCounter +1;
		IF iCounter&gt;100 THEN
			iStep :=10;
			iCounter :=0;
		END_IF	
		
	10://Back to PTE
		IF mGoPTE THEN
			AxAbs_0.bExe :=TRUE;		
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF
		IF MC_Abs_0.Done AND  ibAtPTE THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;50 THEN
				iStep :=15;
				iCounter :=0;			
			END_IF
		END_IF
	
	15://Waiting for Switching Mode
		bReady_OnFly :=FALSE;
		CASE wModeSel OF
				0://Punch-A Side	Forming/Wheel/Scribe
					IF mGoPOP THEN
						iDelayTime_ms :=Tcp.iDelayTime_ms;
						actModeSet :=0;
						bReady_Win:=0;//提前到位=0
						iStep :=20;
					END_IF
			
				1://Undefinition
			
				2://Free mark
					IF mGoPOP THEN
						iDelayTime_ms :=0;
						actModeSet :=2;//标记 自由打标
						bReady_Win:=Def.POP_ReadyWin_Mark;//使用打标提前到位窗
						bFreeMark :=TRUE; //设置自由打标控制参数
						iStep :=50;
					END_IF
				
				3://Punch-AB Side
					IF mGoPOP THEN
						actModeSet :=3;
						IF ibSoftPun THEN
							bReady_Win:=0;//软冲冲压提前到位窗=0
							iStep :=40;
						ELSE
//							bReady_Win:=Def.POP_ReadyWin_Punch;//冲压使用默认冲压提前到位窗
							bReady_Win:=Tcp.iReady_deg;//冲压使用上位传输冲压提前到位窗
							iStep :=30;
						END_IF
					END_IF
					
				4://Round 
				
				5://Mark-With POP
					IF mGoPOP THEN
						iDelayTime_ms :=0;
						actModeSet :=5;//标记 打标模式
						bReady_Win:=Def.POP_ReadyWin_Mark;//使用打标提前到位窗
						iStep :=20;
					END_IF

		END_CASE
		
	20://Punch - Aside - step0 - 到预压POP
		act_20_PunchA_GoPOP();
		IF mGoPOP THEN 
			AxAbs_0.bExe :=TRUE;
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		act_Jump_To_PTE();
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=21;	iCounter :=0;
			END_IF
		END_IF		
		
	21://Punch - Aside - step1 - 等待冲压信号 Pun-ibPunch 
		act_21_PunchA_PunchA();
		AxAbs_0.bExe :=FALSE;	
		act_Jump_To_PTE();
		IF rt_ibPunch.Q OR bPunchExe THEN
			bPunchExe :=FALSE;				
			bReady_OnFly :=FALSE;
			iCounter:=0; iStep :=22;
		END_IF
		
	22://Punch - Aside - step2
		act_22_PunchA_PunchB();
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		AxAbs_1.bExe :=FALSE;
		act_Jump_To_PTE();
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter := iCounter + 1;
			IF iCounter &gt;= iDelayTime_ms/3 THEN
				iCounter:=0; iStep :=23;			
			END_IF
		END_IF
		
	23://Punch - Aside - step3	
		bReady_OnFly :=TRUE;
		act_Jump_To_PTE();
		AxAbs_1.bExe :=TRUE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF		
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=21;			
		END_IF		
	
	
	30://Punch - ABside - step0 - Go POP
		act_20_PunchA_GoPOP();
		act_Jump_To_PTE();
		IF mGoPOP THEN 
			AxAbs_0.bExe :=TRUE;
		END_IF 
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=31;	iCounter :=0;			
			END_IF
		END_IF	
		
	31://Punch - ABside - step1 - Wating Pun-ibPunch
		act_31_PunchAB_PunchA();
		AxAbs_0.bExe :=FALSE;	
		act_Jump_To_PTE();
		IF rt_ibPunch.Q OR bPunchExe THEN
			bPunchExe :=FALSE;
			bReady_OnFly :=FALSE;
			iStep :=32;
		END_IF
		
	32://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.bExe :=TRUE;	
		IF	ActPos&gt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF
		act_Jump_To_PTE();
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=33;	iCounter :=0;			
		END_IF		
		
	33://Punch - ABside - step1 - Wating Pun-ibPunch
		act_33_PunchAB_PunchB();
		AxAbs_0.bExe :=FALSE;	
		act_Jump_To_PTE();
		IF rt_ibPunch.Q OR bPunchExe THEN
			bPunchExe :=FALSE;
			bReady_OnFly :=FALSE;
			iStep :=34;
		END_IF
		
	34://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.bExe :=TRUE;
		IF	ActPos&lt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF	
		act_Jump_To_PTE();
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=31;	iCounter :=0;			
		END_IF	



	40://Punch - ABside SoftPunch - step0 - Go POP
		act_20_PunchA_GoPOP();
		act_Jump_To_PTE();
		IF mGoPOP THEN 
			AxAbs_0.bExe :=TRUE;
		END_IF 	
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=41;	iCounter :=0;			
			END_IF
		END_IF	
		
		
		
	41:
		act_41_PunchSoft_PunchA1();
		AxAbs_0.bExe :=FALSE;	
		act_Jump_To_PTE();
		IF rt_ibPunch.Q OR bPunchExe THEN
			bPunchExe :=FALSE;
			bReady_OnFly :=FALSE;
			iStep :=42;
		END_IF
		
		
		
	42:
		act_42_PunchSoft_PunchA2();
		act_Jump_To_PTE();
		AxAbs_0.bExe :=TRUE;
		AxAbs_1.bExe :=FALSE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=43;	iCounter :=0;			
		END_IF	
		
		
		
	43:
		act_43_PunchSoft_PunchA3();
		act_Jump_To_PTE();
		AxAbs_1.bExe :=TRUE;
		AxAbs_2.bExe :=FALSE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF	
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=44;	iCounter :=0;			
		END_IF
		
		
		
	44:
		AxAbs_2.bExe :=TRUE;
		IF	ActPos&gt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF		
		act_Jump_To_PTE();
		IF MC_Abs_2.Active THEN
			AxAbs_2.bExe :=FALSE;
		END_IF	
		IF MC_Abs_2.Done THEN
			AxAbs_2.bExe :=FALSE;
			iStep :=45;	iCounter :=0;			
		END_IF
		
		
		
	45:
		act_45_PunchSoft_PunchB1();
		AxAbs_0.bExe :=FALSE;
		act_Jump_To_PTE();	
		IF rt_ibPunch.Q OR bPunchExe THEN
			bPunchExe :=FALSE;
			bReady_OnFly :=FALSE;
			iStep :=46;
		END_IF
	


	46:
		act_46_PunchSoft_PunchB2();
		act_Jump_To_PTE();
		AxAbs_0.bExe :=TRUE;
		AxAbs_1.bExe :=FALSE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=47;	iCounter :=0;			
		END_IF	
		
		
		
	47:
		act_47_PunchSoft_PunchB3();
		act_Jump_To_PTE();
		AxAbs_1.bExe :=TRUE;
		AxAbs_2.bExe :=FALSE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF	
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=48;	iCounter :=0;			
		END_IF
		
		
		
	48:
		AxAbs_2.bExe :=TRUE;
		IF	ActPos&lt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF		
		act_Jump_To_PTE();
		IF MC_Abs_2.Active THEN
			AxAbs_2.bExe :=FALSE;
		END_IF	
		IF MC_Abs_2.Done THEN
			AxAbs_2.bExe :=FALSE;
			iStep :=41;	iCounter :=0;			
		END_IF


	50://Free Mark - step0 - Go POP
		act_20_PunchA_GoPOP();
		IF mGoPOP THEN 
			AxAbs_0.bExe :=TRUE;
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		act_Jump_To_PTE();
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=51;	iCounter :=0;
			END_IF
		END_IF		

	51://Free Mark - Aside - step1 - 等待冲压信号 Pun-ibPunch 
		act_21_PunchA_PunchA();
		AxAbs_0.bExe :=FALSE;	
		act_Jump_To_PTE();
		iCounter :=iCounter +1;
		IF rt_ibPunch.Q OR bPunchExe THEN
			bReady_OnFly :=FALSE;
			iCounter:=0; iStep :=52;
		END_IF

	52://Free Mark - Aside - step2
		act_22_PunchA_PunchB();
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		AxAbs_1.bExe :=FALSE;
		act_Jump_To_PTE();
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=53;			
		END_IF

	53://Free Mark - Aside - step3	
		bReady_OnFly :=TRUE;
		act_Jump_To_PTE();
		AxAbs_1.bExe :=TRUE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF		
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=51;			
		END_IF	
	
	(*
	20://PreStep for Switching Mode
		AxAbs_0.Position :=80;		AxAbs_0.Speed :=100;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Buffered;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;	

		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			iStep :=21;
		END_IF	
		
		
	21:
		AxAbs_1.Position :=180;		AxAbs_1.Speed :=20;
		AxAbs_1.Acc := AxAbs_1.Dcc :=360000; AxAbs_1.Jerk :=3600000;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_1.Dir := MC_DIRECTION.mcPositive;	
		AxAbs_1.bExe :=TRUE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF
		IF MC_Abs_1.Done THEN
			iStep :=25;
			AxAbs_1.bExe :=FALSE;
		END_IF
	25:
		iCounter :=iCounter+1;
		IF iCounter&gt;500 THEN
			iStep :=30;
			iCounter :=0;
		END_IF
		
	30://PreStep for Switching Mode
		AxAbs_0.Position :=0;		AxAbs_0.Speed :=100;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcNegative;
		AxAbs_0.bExe :=FALSE;AxAbs_1.bExe :=FALSE;

		iCounter :=iCounter+1;
		IF iCounter&gt;500 THEN
			iStep :=31;
			iCounter :=0;
		END_IF
		
	31:	
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF		
		IF MC_Abs_0.Done THEN
			iStep :=35;
			AxAbs_0.bExe :=FALSE;		
		END_IF
	35:
		iCounter :=iCounter+1;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Buffered;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.bExe :=FALSE;
		AxAbs_1.bExe :=FALSE;
		IF iCounter&gt;1000 THEN
			iStep :=20;
			iCounter :=0;
		END_IF		
		*)
		
END_CASE



</Single>
