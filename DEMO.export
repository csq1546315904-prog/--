      </Single>
      <Single Name="ParentSVNodeGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
      <Array Name="Path" Type="string">
        <Single Type="string">Device</Single>
        <Single Type="string">PLC逻辑</Single>
        <Single Type="string">Application</Single>
      </Array>
