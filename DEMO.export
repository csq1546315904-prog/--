      <Single Name="IsRoot" Type="bool">False</Single>
      <Single Name="MetaObject" Type="{81297157-7ec9-45ce-845e-84cab2b88ade}" Method="IArchivable">
        <Single Name="Guid" Type="System.Guid">347c7057-6bda-4293-8e1f-53dc0ba0ebe3</Single>
        <Single Name="ParentGuid" Type="System.Guid">e8676697-689f-4132-9a50-56de3ab06925</Single>
