            <Single Name="TextBlobForSerialisation" Type="string">TYPE Def_1 :
STRUCT
	
	Speed_Go_PTE :REAL :=100; //Go上死点PTE 速度
	Speed_Go_POP :REAL :=100; //上死点到预压POP 速度
 	
	
	Acc_Go_PTE : REAL :=3600;
	Acc_Go_POP : REAL :=3600;
	Acc_PunchA : REAL :=36000; //冲压A side
	Acc_PunchAB : REAL :=360000; //冲压AB side
	Acc_PunchSoft : REAL :=100000; //软冲 side
	
	CoolFan_Toff :INT :=10; //延时风扇关闭 sec 
	CoolFan_OnTemp :INT :=60; //自动打开温度
	
	PTE_Gap :REAL :=5; //到上死点0的到位窗口
	POP_Gap :REAL :=3; //到预压位角度的到位窗口 不是提前到位信号
	PUP_Gap :REAL :=2; //到下死点角度的到位窗口 不是提前到位信号	
	POP_ReadyWin_Punch :REAL :=10; //冲头冲压返回预压位置的提前到位窗口信号
	POP_ReadyWin_Mark :REAL :=5; //冲头冲压返回预压位置的提前到位窗口信号
	PunchSpeed_Max_Lim :REAL :=425; //冲头最高速度限制值
END_STRUCT
END_TYPE
</Single>
