VAR_GLOBAL
	//IX0 - 本地输入 
	ibModeSel_0 AT %IX0.0:BOOL; //工作模式信号—0
	ibModeSel_1 AT %IX0.1:BOOL; //工作模式信号—1
	ibModeSel_2 AT %IX0.2:BOOL; //工作模式信号—2
	ibPunch 	AT %IX0.3:BOOL ; //冲压信号
	ibGoPOP	 	AT %IX0.4:BOOL; //切换到上死点
	ibAF 		AT %IX0.5:BOOL ; //伺服使能
	ibSoftPun 	AT %IX0.6:BOOL; //软冲模式
	bMode_SetPos: BOOL;
	
	//QX0 - 本地输出 NPN模块	
	qPos_0 		AT %QX0.0:BOOL; //位置信号1—qx0
	qPos_1 		AT %QX0.1:BOOL; //位置信号2—qx0
	qReadyFeed 	AT %QX0.2:BOOL; //进料信号—qx0
	qError		AT %QX0.3 :BOOL; //冲头故障信号—qx0 
	qFan		AT %QX0.4 :BOOL; //风扇—qx0

	//QX20-21 - 扩展输出 PNP模块
	qbPos_0 	AT %QX20.0:BOOL; //位置信号1
	qbPos_1 	AT %QX20.1:BOOL; //位置信号2
	qbReadyFeed AT %QX20.2:BOOL; //进料信号
	qbError		AT %QX20.3 :BOOL; //冲头故障信号  
	qbFan		AT %QX20.4 :BOOL; //风扇
	
	qqbReadyFeed AT %QX20.5:BOOL; //进料信号
	
	iMotorTemp AT %IW15 :INT; //电机温度
	
	wModeSel :WORD;
	EXECUTE:BOOL:=TRUE;
	ibAtPTE:BOOL;
	ibAtPOP:BOOL;
	ibAtPUP:BOOL;
	byPos:BYTE;
	
	POP_Pos :REAL :=121;
	PUP_Pos :REAL :=180;
	PTE_Gap :REAL:=5; //In PTE position
	Punch_Speed :REAL :=400;//rpm
	PSP1_Pos :REAL;
	PSP2_Pos :REAL;
	PSP1_Speed:REAL :=100;
	PSP2_Speed:REAL :=350;
	
	ActPos :LREAL;//当前位置 角度
	PunHeight :LREAL;
	SetPosValue :LREAL;//设置当前位置值
	
	bReset :BOOL;
	bAFOn :BOOL;//使能轴
	wModeSel_Last :WORD;
	bMode_Switching :BOOL;
	bAF_Off :BOOL;//关使能
	bSetPosExe:BOOL;//执行重置绝对编码器位置
	bDriveError :BOOL;
	bDebugEnable : BOOL;
	
	bReady_OnFly :BOOL;//On Fast Read Check;
	bReady_Win :REAL :=10;//返回预压位置许可送料提前窗口
	
	iStep :INT :=0;
	bTest_OnOff AT %MX3200.0:BOOL;//测试模式开关
	bTest_AF AT %MX3200.1:BOOL;//测试模式使能
	bTest_iPOP AT %MX3200.2:BOOL;//测试模式 - 到预压点
	bTest  AT %MX3200.3:BOOL;//测试模式
	bTest_iPunch :BOOL; //测试模式-冲压信号
	bTest_GoPOP :BOOL; //测试模式 - 到预压点
	
	bIdle :BOOL;//通讯状态字
	bModbusSet_Error :BOOL;
	bModbusRead_Error :BOOL;
	bModbusWrite_Error :BOOL;
	
	Ecat_monitor :BYTE;//EtherCAT监控
	Ecat_Error :BOOL;//EtherCAT中断
	
END_VAR

</Single>
