      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">(*CASE iStep OF
	0: //准备及初始化
		bModbusSet :=bRead := bWrite := FALSE;
		iCounter:=0;
		IF NOT Modbus_TCP_Set_0.Execute AND NOT Modbus_TCP_Read_0.Execute THEN
			iStep :=10;
		END_IF
	
	10: //建立与从站连接
		bRead := FALSE;
		bWrite := FALSE;
		bModbusSet := TRUE;
		iCounter :=iCounter +1;
		IF iCounter &gt;5 THEN
			IF Modbus_TCP_Set_0.Error  THEN
				iCounter :=0;				
				bModbusSet := FALSE;
				iStep := 20; 
			ELSE
				IF Modbus_TCP_Set_0.Done THEN
					iCounter :=0;
					tcpsocket :=persistentvars.socket :=Modbus_TCP_Set_0.Socket;
					bModbusSet := FALSE;
					iStep :=20;
				END_IF
			END_IF	
		END_IF
		
	20:	//进行一次数据读取
		bRead :=TRUE;
		iCounter :=iCounter +1;
		IF iCounter&gt;2 THEN
			IF 	Modbus_TCP_Read_0.Error OR Modbus_TCP_Set_0.Error THEN
				iStep := iCounter :=0; //报错跳转
			ELSE
				IF 	Modbus_TCP_Read_0.Done THEN
					iCounter :=0; 
					iStep :=30; //解析数据
					bRead :=FALSE;
				END_IF
			END_IF
		END_IF	

	30:	//进行一次数据写入
		bWrite :=TRUE;
		iCounter :=iCounter +1;
		IF iCounter&gt;2 THEN
			IF 	Modbus_TCP_Write_0.Error OR Modbus_TCP_Set_0.Error THEN
				iStep := iCounter :=0; //报错跳转
			ELSE
				IF 	Modbus_TCP_Write_0.Done THEN
					iCounter :=0; 
					iStep :=40; //解析数据
					bWrite := FALSE;
				END_IF
			END_IF
		END_IF			
	
	40: //分析解析Modbus数据
		bRead :=FALSE;
		bWrite := FALSE;
		iCounter :=iCounter +1;
		//处理读入的数据		
		Tcp.iPOP_mm := TO_REAL(rdata[0])*0.1;
		Tcp.iReady_mm := TO_REAL(rdata[1])*0.1;	
	    Tcp.iPUP_mm := TO_REAL(rdata[2])*0.1;
	    Tcp.iDelayTime_ms := TO_UINT(rdata[3]*10);
	    Tcp.iPSP2_mm := TO_REAL(rdata[4])*0.1;
		Tcp.iPSP1_mm := TO_REAL(rdata[5])*0.1;
		Tcp.iPunchSpeed := TO_REAL(rdata[6])*1;
		Tcp.iPunchSpeed_Max := TO_REAL(rdata[7])*1;

		
		IF Tcp.iPTE_mm&gt;20 AND Tcp.iPunchSpeed_Max&gt;100 THEN
			Tcp.iRead_OK :=Tcp.iRead_OK+1;
			IF Tcp.iRead_OK&gt;32000 THEN
				Tcp.iRead_OK :=100;
			END_IF
		ELSE
			Tcp.iRead_OK :=0;	
		END_IF
			
		IF iCounter &gt;1 THEN
			iCounter :=0;
			iStep :=20;
		END_IF
END_CASE

//通讯连接
Modbus_TCP_Set_0(	Execute:= bModbusSet, 	
	Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH,	IP:= ipFanuc);

//读从站数据	
Modbus_TCP_Read_0(
	Execute:= bRead, 	
	Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH,	Socket:= tcpsocket,	ID:= 1,
	AddrType:= com_lib.Modbus_READ_REG_TYPE.HoldingReg, 
	Addr:= 0, 	Num:= 10,	TimeOut:= 1000, 
	pByteBuf:= ADR(rdata), 	ByteBufSize:= 20, 
	Done=&gt; , 	Busy=&gt; ,	Error=&gt; ,	ErrorID=&gt; );
	
//写从站数据
Modbus_TCP_Write_0(
	Execute:= bWrite, 
	Chn:= COM_LIB.ModbusTcp_CHN_TYPE.ETH, Socket:= tcpsocket, ID:= 1, 
	AddrType:= com_lib.Modbus_WRITE_REG_TYPE.MultiRegisters, 
	Addr:= 20, Num:= 10, TimeOut:= 1000, 
	pByteBuf:= ADR(wdata), ByteBufSize:= 20, 
	Done=&gt; , Busy=&gt; , Error=&gt; , ErrorID=&gt; );


//通讯故障	
IF 	Modbus_TCP_Set_0.Error OR iStep&lt;20 THEN
	bModbusSet_Error :=TRUE;
ELSE
//	IF	Modbus_TCP_Set_0.Execute AND Modbus_TCP_Set_0.Done AND NOT Modbus_TCP_Set_0.Error THEN
		bModbusSet_Error :=FALSE;
//	END_IF 	
END_IF

IF 	Modbus_TCP_Read_0.Error THEN
	bModbusRead_Error :=TRUE;
ELSE
	IF	Modbus_TCP_Read_0.Execute AND Modbus_TCP_Read_0.Done AND NOT Modbus_TCP_Read_0.Error THEN
		bModbusRead_Error :=FALSE;
	END_IF 	
END_IF

IF 	Modbus_TCP_Write_0.Error THEN
	bModbusWrite_Error :=TRUE;
ELSE
	IF	Modbus_TCP_Write_0.Execute AND Modbus_TCP_Write_0.Done AND NOT Modbus_TCP_Write_0.Error THEN
		bModbusWrite_Error :=FALSE;
	END_IF 	
END_IF

//Modbus通讯异常
Tcp.bError := bModbusSet_Error  OR bModbusRead_Error OR bModbusWrite_Error;
FB_BLINK_Idle(Enable:= NOT Tcp.bError, Period:= T#500ms, Q=&gt; bIdle);
IF bIdle THEN
	wdata[6] := 1;
ELSE
	wdata[6] := 0;
END_IF*)
(*
    Tcp.iPOP_mm := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[0])*0.1;
    Tcp.iReady_mm := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[1])*0.1;
    Tcp.iPUP_mm := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[2])*0.1;
    Tcp.iDelayTime_ms := TO_UINT(ModbusTCP_MasterVars.Slave1Id1RBuff[3]*10);
    Tcp.iPSP2_mm := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[4])*0.1;
    Tcp.iPSP1_mm := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[5])*0.1;
    Tcp.iPunchSpeed := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[6]);
    Tcp.iPunchSpeed_Max := TO_REAL(ModbusTCP_MasterVars.Slave1Id1RBuff[7]);
*)
IF NOT bTest THEN
	IF TCP.intermediate_iPunchSpeed_Max&gt;Def.PunchSpeed_Max_Lim THEN 
		Tcp.iPunchSpeed_Max := Def.PunchSpeed_Max_Lim;
	ELSE	
		Tcp.iPunchSpeed_Max := TCP.intermediate_iPunchSpeed_Max;
	END_IF
END_IF

//Modbus通讯异常
Tcp.bError := bModbusSet_Error  OR bModbusRead_Error OR bModbusWrite_Error;
FB_BLINK_Idle(Enable:= NOT Tcp.bError, Period:= T#500MS, Q=&gt; bIdle);

//处理读入的数据
IF NOT bTest THEN
	Tcp.iPOP_mm := TO_REAL(TCP.intermediate_iPOP_mm)*0.1;
	Tcp.iReady_mm := TO_REAL(TCP.intermediate_iReady_mm)*0.1;	
	Tcp.iPUP_mm := TO_REAL(TCP.intermediate_iPUP_mm)*0.1;
	Tcp.iDelayTime_ms := TO_UINT(TCP.intermediate_iDelayTime_ms*10);
	Tcp.iPSP2_mm := TO_REAL(TCP.intermediate_iPSP2_mm)*0.1;
	Tcp.iPSP1_mm := TO_REAL(TCP.intermediate_iPSP1_mm)*0.1;
	Tcp.iPunchSpeed := TO_REAL(TCP.intermediate_iPunchSpeed)*1;
	Tcp.iPunchSpeed_Max := TO_REAL(Tcp.iPunchSpeed_Max)*1;
END_IF

//高度转换角度计算
FB_HeightToAngle_iPTE(HeightMM:= Tcp.iPTE_mm, AngleDeg=&gt; Tcp.iPTE_deg);
FB_HeightToAngle_iPOP(HeightMM:= Tcp.iPOP_mm, AngleDeg=&gt; Tcp.iPOP_deg);
FB_HeightToAngle_iPUP(HeightMM:= Tcp.iPUP_mm, AngleDeg=&gt; Tcp.iPUP_deg);
FB_HeightToAngle_iReady(HeightMM:= Tcp.iReady_mm, AngleDeg=&gt; iReady_deg );
FB_HeightToAngle_iPSP1(HeightMM:= Tcp.iPSP1_mm, AngleDeg=&gt; Tcp.iPSP1_deg);
FB_HeightToAngle_iPSP2(HeightMM:= Tcp.iPSP2_mm, AngleDeg=&gt; Tcp.iPSP2_deg);

//转换到位窗口
Tcp.iReady_deg := 180.0 - iReady_deg;
			</Single>
            <Single Name="LineInfoPersistence" Type="string">bf53116a-f2b6-4f3e-9991-deae112b9195_Impl_LineIds</Single>
          </Single>
        </Single>
        <Single Name="Interface" Type="{a9ed5b7e-75c5-4651-af16-d2c27e98cb94}" Method="IArchivable">
