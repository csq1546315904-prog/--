            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM Punch_PA
VAR
	iCounter :UINT :=0;
	iDelayTime_ms : UINT :=0;
	actModeSet :INT;
	bFreeMark :bool; //自由打标模式激活中
END_VAR
</Single>
