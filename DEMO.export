            <Single Name="TextBlobForSerialisation" Type="string">// ------------------- 主逻辑 -------------------

// Set 优先级最高
IF Set THEN
    Out := TRUE;
ELSIF Reset THEN
    Out := FALSE;
ELSE
    // 检测按键上升沿
    IF (Key = TRUE) AND (prevKey = FALSE) THEN
        Out := NOT Out; // 翻转
    END_IF
END_IF

// 更新上一次按键状态
prevKey := Key;

</Single>
