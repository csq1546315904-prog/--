            <Single Name="TextBlobForSerialisation" Type="string">TYPE Tcp_1 :
STRUCT
	bError :BOOL; 
	iRead_OK :INT; //读取数据正常计数器
	
	iPTE_mm :REAL :=32; //Data_1 换模位置 
	iPTE_deg :REAL; //Data_1 换模位置

	iPOP_mm :REAL;//Data_2 预压位置 上死点
	iPOP_deg :REAL;//Data_2 预压位置 上死点
	
	iPUP_mm :REAL; //Data_3 下压位置
	iPUP_deg :REAL;//Data_3 下压位置

	iReady_mm :REAL; //Data_4换模位置 ready 信号区域
	iReady_deg :REAL;//Data_4换模位置 ready 信号区域
	
	iDelayTime_ms : UINT;//Data_5  下压点延时

	iPunchSpeed_Trans :REAL; //Data_6 冲压速度	
	iPunchSpeed_Max :REAL; //Data_6 冲压速度
	iSoftPunch : INT;//Data_7 软冲模式
	
	iPSP1_mm :REAL ;//Data_8 软冲减速点1
	iPSP1_deg :REAL ;//Data_8 软冲减速点1
	
	iPunchSpeed :REAL; //Data_9 冲压穿板速度
	
	iFormMode :INT; //Data_10 压印模式 0-可调 1-机械点
	
	iPSP2_mm :REAL ;//Data_11 软冲减速点1
	iPSP2_deg :REAL ;//Data_11 软冲减速点1
	
	
	intermediate_iPOP_mm : WORD;
	intermediate_iReady_mm : WORD;
    intermediate_iPUP_mm : WORD;
    intermediate_iDelayTime_ms : WORD;
    intermediate_iPSP2_mm : WORD;
    intermediate_iPSP1_mm : WORD;
    intermediate_iPunchSpeed : WORD;
    intermediate_iPunchSpeed_Max : WORD;

END_STRUCT
END_TYPE
</Single>
