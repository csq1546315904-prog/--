            <Single Name="TextBlobForSerialisation" Type="string">(* 2s呼吸灯 占空比50%*)
tBlink(IN:=TRUE, PT:=T#1S);    // 定时 1s
IF tBlink.Q THEN
    LedOut := NOT LedOut;      // 翻转输出
    tBlink(IN:=FALSE);         // 重置定时器
END_IF;</Single>
