      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">IF NOT bAFOn OR NOT  AxisVars.Axis0.AxisMotionState.ServoEnabled THEN
	iStep := iCounter:=0;
END_IF 

CASE iStep OF
	0://Power Off, reset data
		AxAbs_0.bExe := AxAbs_1.bExe :=AxAbs_2.bExe :=FALSE;
		IF bAFOn AND NOT MC_POWER0.Error AND AxisVars.Axis0.AxisMotionState.ServoEnabled THEN
			iStep :=7;
		END_IF
		
	7://PrePTE
		AxAbs_0.Position :=0;		AxAbs_0.Speed :=100*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcNegative;	
		AxAbs_0.bExe := AxAbs_1.bExe :=AxAbs_2.bExe :=FALSE;
		IF ActPos&gt;180 THEN
			AxAbs_0.Dir := MC_DIRECTION.mcPositive;
			AxAbs_0.Position :=360;
		END_IF
		 iCounter:= iCounter +1;
		IF iCounter&gt;100 THEN
			iStep :=10;
			iCounter :=0;
		END_IF	
		
	10://Back to PTE
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF
		IF MC_Abs_0.Done AND  ibAtPTE THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;200 THEN
				iStep :=15;
				iCounter :=0;			
			END_IF
		END_IF
	
	15://Waiting for Switching Mode
		bReady_OnFly :=FALSE;
		CASE wModeSel OF
				0://Punch-A Side
					IF rt_ibGoPOP.Q THEN
						iStep :=20;
					END_IF
					
				1://Wheel
				
			
				2://Forming
	
				
				3://Punch-AB Side
					IF rt_ibGoPOP.Q THEN
						IF ibSoftPun THEN
							iStep :=40;
						ELSE
							iStep :=30;
						END_IF
					END_IF
					
				4://Round 
		END_CASE
		
	20://Punch - Aside - step0 - Go POP
		AxAbs_0.Position :=POP_Pos;		AxAbs_0.Speed :=100*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;	
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=21;	iCounter :=0;			
			END_IF
		END_IF		
		
	21://Punch - Aside - step1 - Wating Pun-ibPunch
		AxAbs_0.Position :=PUP_Pos;		AxAbs_0.Speed :=Punch_Speed*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;
		AxAbs_0.bExe :=FALSE;	
		IF rt_ibGoPOP.Q OR wModeSel&lt;&gt;0 THEN
			iStep :=7;//Back to PTE
		END_IF
		IF rt_ibPunch.Q THEN
			bReady_OnFly :=FALSE;
			iStep :=22;
		END_IF

		
	22://Punch - Aside - step2
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		AxAbs_1.Position :=POP_Pos;		AxAbs_1.Speed :=Punch_Speed*6;
		AxAbs_1.Acc := AxAbs_1.Dcc :=360000; AxAbs_1.Jerk :=3600000;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_1.Dir := MC_DIRECTION.mcNegative;	
		AxAbs_1.bExe :=FALSE;
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=23;			
		END_IF		
	23://Punch - Aside - step3	
		bReady_OnFly :=TRUE;
		AxAbs_1.bExe :=TRUE;
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=21;			
		END_IF		
	
	
	30://Punch - ABside - step0 - Go POP
		AxAbs_0.Position :=POP_Pos;		AxAbs_0.Speed :=100*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;	
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=31;	iCounter :=0;			
			END_IF
		END_IF	
		
	31://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.Position :=360 - POP_Pos;		AxAbs_0.Speed :=Punch_Speed*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;
		AxAbs_0.bExe :=FALSE;	
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF rt_ibPunch.Q THEN
			bReady_OnFly :=FALSE;
			iStep :=32;
		END_IF
		
	32://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.bExe :=TRUE;
		IF	ActPos&gt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=33;	iCounter :=0;			
		END_IF		
		
	33://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.Position :=POP_Pos;		AxAbs_0.Speed :=Punch_Speed*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcNegative;
		AxAbs_0.bExe :=FALSE;	
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF rt_ibPunch.Q THEN
			bReady_OnFly :=FALSE;
			iStep :=34;
		END_IF
		
	34://Punch - ABside - step1 - Wating Pun-ibPunch
		AxAbs_0.bExe :=TRUE;
		IF	ActPos&lt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF	
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=31;	iCounter :=0;			
		END_IF	



	40://Punch - ABside SoftPunch - step0 - Go POP
		AxAbs_0.Position :=POP_Pos;		AxAbs_0.Speed :=100*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;	
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iCounter :=iCounter+1;
			IF iCounter&gt;100 THEN
				iStep :=41;	iCounter :=0;			
			END_IF
		END_IF	
		
		
		
	41:
		AxAbs_0.Position :=140;		AxAbs_0.Speed :=Punch_Speed*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.BlendingLow;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;
		AxAbs_0.bExe :=FALSE;	
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF rt_ibPunch.Q THEN
			bReady_OnFly :=FALSE;
			iStep :=42;
		END_IF
		
		
		
	42:
		AxAbs_0.bExe :=TRUE;
		AxAbs_1.Position :=180;		AxAbs_1.Speed :=100*6;
		AxAbs_1.Acc := AxAbs_1.Dcc :=360000; AxAbs_1.Jerk :=3600000;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.BlendingLow;
		AxAbs_1.Dir := MC_DIRECTION.mcPositive;
		AxAbs_1.bExe :=FALSE;
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=43;	iCounter :=0;			
		END_IF	
		
		
		
	43:
		AxAbs_1.bExe :=TRUE;
		AxAbs_2.Position :=360 - POP_Pos;		AxAbs_2.Speed :=Punch_Speed*6;
		AxAbs_2.Acc := AxAbs_2.Dcc :=360000; AxAbs_2.Jerk :=3600000;
		AxAbs_2.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_2.Dir := MC_DIRECTION.mcPositive;
		AxAbs_2.bExe :=FALSE;
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF	
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=44;	iCounter :=0;			
		END_IF
		
		
		
	44:
		AxAbs_2.bExe :=TRUE;
		IF	ActPos&gt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF		
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_2.Active THEN
			AxAbs_2.bExe :=FALSE;
		END_IF	
		IF MC_Abs_2.Done THEN
			AxAbs_2.bExe :=FALSE;
			iStep :=45;	iCounter :=0;			
		END_IF
		
		
		
	45:
		AxAbs_0.Position :=220;		AxAbs_0.Speed :=Punch_Speed*6;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.BlendingLow;
		AxAbs_0.Dir := MC_DIRECTION.mcNegative;
		AxAbs_0.bExe :=FALSE;	
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF rt_ibPunch.Q THEN
			bReady_OnFly :=FALSE;
			iStep :=46;
		END_IF
	


	46:
		AxAbs_0.bExe :=TRUE;
		AxAbs_1.Position :=180;		AxAbs_1.Speed :=100*6;
		AxAbs_1.Acc := AxAbs_1.Dcc :=360000; AxAbs_1.Jerk :=3600000;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.BlendingLow;
		AxAbs_1.Dir := MC_DIRECTION.mcNegative;
		AxAbs_1.bExe :=FALSE;
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			iStep :=47;	iCounter :=0;			
		END_IF	
		
		
		
	47:
		AxAbs_1.bExe :=TRUE;
		AxAbs_2.Position :=POP_Pos;		AxAbs_2.Speed :=Punch_Speed*6;
		AxAbs_2.Acc := AxAbs_2.Dcc :=360000; AxAbs_2.Jerk :=3600000;
		AxAbs_2.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_2.Dir := MC_DIRECTION.mcNegative;
		AxAbs_2.bExe :=FALSE;
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF	
		IF MC_Abs_1.Done THEN
			AxAbs_1.bExe :=FALSE;
			iStep :=48;	iCounter :=0;			
		END_IF
		
		
		
	48:
		AxAbs_2.bExe :=TRUE;
		IF	ActPos&lt;180 THEN
			bReady_OnFly :=TRUE;
		END_IF		
		IF rt_ibGoPOP.Q THEN
			iStep :=7;//Back to PTE
		END_IF
		IF MC_Abs_2.Active THEN
			AxAbs_2.bExe :=FALSE;
		END_IF	
		IF MC_Abs_2.Done THEN
			AxAbs_2.bExe :=FALSE;
			iStep :=41;	iCounter :=0;			
		END_IF
	
	(*
	20://PreStep for Switching Mode
		AxAbs_0.Position :=80;		AxAbs_0.Speed :=100;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Buffered;
		AxAbs_0.Dir := MC_DIRECTION.mcPositive;	

		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF	
		IF MC_Abs_0.Done THEN
			iStep :=21;
		END_IF	
		
		
	21:
		AxAbs_1.Position :=180;		AxAbs_1.Speed :=20;
		AxAbs_1.Acc := AxAbs_1.Dcc :=360000; AxAbs_1.Jerk :=3600000;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_1.Dir := MC_DIRECTION.mcPositive;	
		AxAbs_1.bExe :=TRUE;
		IF MC_Abs_1.Active THEN
			AxAbs_1.bExe :=FALSE;
		END_IF
		IF MC_Abs_1.Done THEN
			iStep :=25;
			AxAbs_1.bExe :=FALSE;
		END_IF
	25:
		iCounter :=iCounter+1;
		IF iCounter&gt;500 THEN
			iStep :=30;
			iCounter :=0;
		END_IF
		
	30://PreStep for Switching Mode
		AxAbs_0.Position :=0;		AxAbs_0.Speed :=100;
		AxAbs_0.Acc := AxAbs_0.Dcc :=360000; AxAbs_0.Jerk :=3600000;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.Dir := MC_DIRECTION.mcNegative;
		AxAbs_0.bExe :=FALSE;AxAbs_1.bExe :=FALSE;

		iCounter :=iCounter+1;
		IF iCounter&gt;500 THEN
			iStep :=31;
			iCounter :=0;
		END_IF
		
	31:	
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			AxAbs_0.bExe :=FALSE;
		END_IF		
		IF MC_Abs_0.Done THEN
			iStep :=35;
			AxAbs_0.bExe :=FALSE;		
		END_IF
	35:
		iCounter :=iCounter+1;
		AxAbs_0.BufferMode :=MC_BUFFER_MODE.Buffered;
		AxAbs_1.BufferMode :=MC_BUFFER_MODE.Aborting;
		AxAbs_0.bExe :=FALSE;
		AxAbs_1.bExe :=FALSE;
		IF iCounter&gt;1000 THEN
			iStep :=20;
			iCounter :=0;
		END_IF		
		*)
		
END_CASE



