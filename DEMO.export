            <Single Name="TextBlobForSerialisation" Type="string">IF bTest THEN
	Tcp.iPTE_mm := 32;
//	Tcp.iPOP_mm :=16.1 ;
	Tcp.iPUP_mm :=3.1;
	Tcp.iReady_mm :=30;
	Tcp.iDelayTime_ms :=1000;
	Tcp.iPunchSpeed_Max :=400;
	Tcp.iSoftPunch :=0;
	Tcp.iPSP1_mm := 6.1;
	Tcp.iFormMode :=0;
	Tcp.iPSP2_mm :=0.1;
	Tcp.iPunchSpeed :=100;	
ELSE
	wModeSel :=mModeSel;	
END_IF






</Single>
