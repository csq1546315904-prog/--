            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM prModusTcp_Fanuc
VAR
	iStep :int;
	Modbus_TCP_Set_0: Modbus_TCP_Set;
	bModbusSet :BOOL;
	Modbus_TCP_Read_0 :Modbus_TCP_Read;
	ipFanuc : ARRAY [0..3] OF BYTE:=[172,16,10,11];
	iCounter :INT;
	bRead :BOOL;
	tcpsocket:BYTE;
	rdata:ARRAY[0..9] OF WORD;
//	bModbusSet_Error :BOOL;
//	bModbusRead_Error :BOOL;
//	bModbusWrite_Error :BOOL;	
	Modbus_TCP_Write_0 :Modbus_TCP_Write;
	bWrite :BOOL;
	wdata:ARRAY[0..9] OF WORD;
//	bIdle :BOOL;
	iReady_deg :REAL;//Data_4换模位置 ready 信号区域
		
	FB_HeightToAngle_iPTE :FB_HeightToAngle;
	FB_HeightToAngle_iPOP :FB_HeightToAngle;
	FB_HeightToAngle_iPUP :FB_HeightToAngle;
	FB_HeightToAngle_iReady :FB_HeightToAngle;
	FB_HeightToAngle_iPSP1 :FB_HeightToAngle;
	FB_HeightToAngle_iPSP2 :FB_HeightToAngle;
	FB_BLINK_Idle:FB_BLINK;
END_VAR
</Single>
