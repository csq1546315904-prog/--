        <Single Name="ParentGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
        <Single Name="Name" Type="string">DebugMode</Single>
        <Dictionary Type="{2c41fa04-1834-41c1-816e-303c7aa2c05b}" Name="Properties" />
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">638988113698880729</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">// ---------------- 上升沿检测 ----------------
trHome(CLK := bHomeBtn);
trMovePos(CLK := bMovePosBtn);
trMoveNeg(CLK := bMoveNegBtn);
act_SetHome();

// ---------------- 安全条件监测 ----------------
// 若调试模式关闭或使能关闭 -&gt; 立即复位到初始状态
IF (NOT bDebugModeEnable) OR (NOT bDebugEnableBtn) THEN
    // 状态初始化
    bDebugEnable :=FALSE;
	bMCHomeExe := FALSE;
    iCounter :=0;
    iDebugErr :=0;
    nStep := 0;
	iRetryCount :=0;
    RETURN; // 强制退出本周期，防止执行后续逻辑
END_IF

// ---------------- 主控制逻辑 ----------------
CASE nStep OF

    0: // 等待调试模式 + 伺服使能
		IF bDebugEnableBtn AND (iRetryCount &lt; 5) THEN
			bDebugEnable :=TRUE;
			nStep :=1;
		ELSIF iRetryCount &gt;= 5 THEN
			iDebugErr.0 := TRUE;
		END_IF
	1:
		IF AxisVars.Axis0.AxisMotionState.ServoEnabled AND NOT MC_POWER0.Error THEN
			nStep :=10;
		ELSIF MC_POWER0.Error THEN
			bDebugEnable :=FALSE;
			iCounter :=0;
			nStep :=2;
		END_IF
	2:
		iCounter := iCounter + 1;
        IF iCounter &gt;= 200 THEN
            iCounter := 0;
            nStep := 3;            // 开始执行Reset
        END_IF
	3:
		iCounter := iCounter + 1;
		IF iCounter &lt; 100 THEN
			bReset :=TRUE;
		ELSIF (iCounter &gt;= 100) AND (iCounter &lt; 200) THEN
			bReset :=FALSE;
		ELSIF iCounter &gt;= 200 THEN
			iRetryCount := iRetryCount + 1;
			iCounter := 0;
            nStep := 0;
        END_IF
    10: // 等待操作命令
		AxAbs_0.bExe := bMCHomeExe := FALSE;
		iCounter := 0;
        IF trHome.Q THEN
            nStep := 20;
			iDebugErr := 0;
        ELSIF trMovePos.Q THEN
            nStep := 30;
			iDebugErr := 0;
        ELSIF trMoveNeg.Q THEN
            nStep := 40;
			iDebugErr := 0;
        END_IF

    20: // -------- 回原操作 --------
        bMCHomeExe :=TRUE;
        IF fbHome.Done THEN
            bMCHomeExe := FALSE;
            nStep := 10;
        ELSIF fbHome.Error THEN
			bMCHomeExe := FALSE;
            iDebugErr.1 := TRUE;
            nStep := 10;
        END_IF

    30: // -------- 正向移动 --------
        act_MovePositive();
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			nStep :=35;
		END_IF		
		
	35:	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			nStep :=10;		
		ELSIF MC_Abs_0.Error THEN
			iDebugErr.2 := TRUE;
			AxAbs_0.bExe :=FALSE;
            nStep := 10;
		END_IF		

    40: // -------- 反向移动 --------
        act_MoveNegative();
		AxAbs_0.bExe :=TRUE;
		IF MC_Abs_0.Active THEN
			nStep :=45;
		END_IF

	45:	
		IF MC_Abs_0.Done THEN
			AxAbs_0.bExe :=FALSE;
			nStep :=10;			
		ELSIF MC_Abs_0.Error THEN
			iDebugErr.2 := TRUE;
			AxAbs_0.bExe :=FALSE;
            nStep := 10;
		END_IF

END_CASE;</Single>
