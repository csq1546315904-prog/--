            <Single Name="TextBlobForSerialisation" Type="string">// 7 - GoPTE
AxAbs_0.Position :=0;		
AxAbs_0.Speed :=Def.Speed_Go_PTE*6;
AxAbs_0.Acc := AxAbs_0.Dcc :=Def.Acc_Go_PTE; 
AxAbs_0.Jerk :=3600000;
AxAbs_0.BufferMode :=MC_BUFFER_MODE.Aborting;
AxAbs_0.Dir := MC_DIRECTION.mcNegative;

IF ActPos&gt;180 THEN
	AxAbs_0.Dir := MC_DIRECTION.mcPositive;
	AxAbs_0.Position :=360;
END_IF
</Single>
