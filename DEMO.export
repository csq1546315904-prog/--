  TONList : ARRAY[0..1] OF TON;
  NowModbusRWIndex : INT;
  Cycle : INT;  Modbus_TCP_Set1 : Modbus_TCP_Set;
  IP1 : ARRAY [0..3] OF BYTE := [172, 16, 10, 11];
  ModbusRead1 : Modbus_TCP_Read;
  ModbusWrite2 : Modbus_TCP_Write;
  i : INT;
