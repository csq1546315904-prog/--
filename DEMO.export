    <Single Type="{6198ad31-4b98-445c-927f-3258a0e82fe3}" Method="IArchivable">
      <Single Name="IsRoot" Type="bool">False</Single>
      <Single Name="MetaObject" Type="{81297157-7ec9-45ce-845e-84cab2b88ade}" Method="IArchivable">
        <Single Name="Guid" Type="System.Guid">549d281f-417b-4c7a-a4f1-9b8b18daeab3</Single>
        <Single Name="ParentGuid" Type="System.Guid">a1713586-810c-4501-8c65-3ad6682175d9</Single>
        <Single Name="Name" Type="string">Motion_IO</Single>
        <Dictionary Type="{2c41fa04-1834-41c1-816e-303c7aa2c05b}" Name="Properties" />
        <Single Name="TypeGuid" Type="System.Guid">6f9dac99-8de1-4efc-8465-68ac443b7d08</Single>
        <Array Name="EmbeddedTypeGuids" Type="System.Guid">
          <Single Type="System.Guid">a9ed5b7e-75c5-4651-af16-d2c27e98cb94</Single>
          <Single Type="System.Guid">3b83b776-fb25-43b8-99f2-3c507c9143fc</Single>
        </Array>
        <Single Name="Timestamp" Type="long">638985356397083445</Single>
      </Single>
      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">//当前位置
ActPos :=AxisVars.Axis0.AxisMotionState.ActPosition;

//冲压及预压信号触发
rt_ibPunch(CLK:= (ibPunch OR bTest_iPunch) AND mGoPOP AND FALSE, Q=&gt; );
IF (ibPunch OR bTest_iPunch) AND mGoPOP THEN 
	bPunchExe:=TRUE;
ELSE
	bPunchExe :=FALSE;	
END_IF
IF mGoPTE THEN 
	bPunchExe :=FALSE;
END_IF

//rt_ibGoPOP(CLK:= ibGoPOP OR bTest_iPOP, Q=&gt; );
IF ibGoPOP OR bTest_GoPOP THEN 
	mGoPOP:=TRUE;
	mGoPTE:=FALSE;	
ELSE
	mGoPOP:=FALSE;
	mGoPTE:=TRUE;
END_IF

//Check at PTE 是否在上死点位置
IF ABS(ActPos - 0)&lt;Def.PTE_Gap THEN
	ibAtPTE:=TRUE;
ELSE
	IF ABS(ActPos - 360)&lt;Def.PTE_Gap THEN
		ibAtPTE:=TRUE;
	ELSE
		ibAtPTE:=FALSE;	
	END_IF
END_IF

//Check at 是否发出送料信号
IF ActPos &lt;(Tcp.iPOP_deg + Def.POP_Gap) OR (ActPos&gt;180 
		AND ActPos&gt;(360-Tcp.iPOP_deg - Def.POP_Gap)) OR ibAtPTE THEN
	mReady:=TRUE;
ELSE
	IF bReady_OnFly AND 
	((ActPos &lt;(Tcp.iPOP_deg+bReady_Win)) OR (ActPos&gt;180 AND ActPos&gt;(360-Tcp.iPOP_deg-bReady_Win) ))  THEN
		mReady:=TRUE;
	ELSE
		mReady:=FALSE;	
	END_IF
END_IF
qbReadyFeed :=mReady;
qqbReadyFeed :=mReady;

//Check at POP 是否在预压点位置
ibAtPOP :=mReady AND NOT ibAtPTE;

//Check at PUP 是否在下死点位置
IF (ActPos &gt;(Tcp.iPUP_deg - Def.PUP_Gap)) AND (ActPos &lt;(Tcp.iPUP_deg + Def.PUP_Gap)) THEN
	ibAtPUP:=TRUE;
ELSE
	ibAtPUP:=FALSE;
END_IF

//输出映射到 本地QX0-NPN模块
CASE byPos OF
	1:
		qPos_0 :=TRUE;
		qPos_1 :=FALSE;
	2:
		qPos_0 :=FALSE;
		qPos_1 :=TRUE;
	4:
		qPos_0 :=TRUE;
		qPos_1 :=TRUE;		
ELSE
		qPos_0 :=FALSE;
		qPos_1 :=FALSE;
END_CASE;

//输出映射到 LocalBus QX20/21-PNP模块
qbPos_0 :=qPos_0;
qbPos_1 :=qPos_1;


//输出映射到 本地QX0-NPN模块
qReadyFeed :=qbReadyFeed;
qError :=qbError;
qFan :=qbFan;

 </Single>
            <Single Name="LineInfoPersistence" Type="string">549d281f-417b-4c7a-a4f1-9b8b18daeab3_Impl_LineIds</Single>
