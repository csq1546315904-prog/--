          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">IF Enable THEN
    // 启动定时器，定时时间为周期的一半
    Timer(IN := NOT Timer.Q, PT := Period / 2);
    
    // 当定时器计时完成时，反转输出状态
    IF Timer.Q THEN
        State := NOT State;
        Timer(IN := FALSE); // 重置定时器
    END_IF;
    
    Q := State; // 输出当前状态
ELSE
    // 未使能时，输出默认值（通常为 FALSE）
    Q := FALSE;
    Timer(IN := FALSE);
    State := FALSE;
END_IF;</Single>
            <Single Name="LineInfoPersistence" Type="string">55f373e8-cd0e-4fe4-a9dc-326b682eab3a_Impl_LineIds</Single>
          </Single>
