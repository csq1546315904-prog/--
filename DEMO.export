            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_HeightToAngle
VAR_INPUT
    HeightMM : REAL; (* 输入高度，单位mm，范围 0~32 *)
END_VAR
VAR_OUTPUT
    AngleDeg : REAL; (* 输出角度，单位°，范围 0~180 *)
END_VAR
VAR
    RR      : REAL := 16.0;   (* 曲柄半径 *)
    L      : REAL := 220.0;  (* 连杆长度 *)
    y_min  : REAL;
    Y      : REAL;
    k      : REAL;
	xll		:REAL;
END_VAR</Single>
