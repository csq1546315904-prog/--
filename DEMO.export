            <Single Name="TextBlobForSerialisation" Type="string">// PLCOpen 功能块
PROGRAM Motion
VAR
	POWER_ENABLE0:BOOL;
	POWER_STATUS0:BOOL;
	POWER_ERRORID:WORD;
	
	RESET_EXECUTE0:BOOL;
	RESET_DONE0:BOOL;
	RESET_BUSY0:BOOL;
	RESET_ERROR0:BOOL;
	RESET_ERRORID0:WORD;
	
	STOP_EXECUTE0:BOOL;
	STOP_DECELERATION0:LREAL:=10;
	STOP_JERK0:LREAL:=10;
	STOP_DONE0:BOOL;
	STOP_BUSY0:BOOL;
	STOP_COMMANDABORTED:BOOL;
	STOP_ERROR0:BOOL;
	STOP_ERRORID0:WORD;
	
	MODE_EXECUTE0:BOOL;
	MODE_CONTROLLERMODE:MC_CONTROLLER_MODE;
	MODE_DONE0:BOOL;
	MODE_BUSY0:BOOL;
	MODE_ERROR0:BOOL;
	MODE_ERRORID0:WORD;
	
	ABSOLUTE_EXECUTE0:BOOL;
	ABSOLUTE_POSITION0:LREAL:=90;
	ABSOLUTE_VELOCITY0:LREAL:=1800;
	ABSOLUTE_ACCELERATION0:LREAL:=36000000;
	ABSOLUTE_DECELERATION0:LREAL:=36000000;
	ABSOLUTE_JERK0:LREAL:=360000000;
	ABSOLUTE_DIRECTION0:MC_DIRECTION;
	ABSOLUTE_BUFFERMODE0:MC_BUFFER_MODE;
	ABSOLUTE_DONE0:BOOL;
	ABSOLUTE_BUSY0:BOOL;
	ABSOLUTE_ACTIVE0:BOOL;
	ABSOLUTE_COMMANDABORTED0:BOOL;
	ABSOLUTE_ERROR0:BOOL;
	ABSOLUTE_ERRORID0:WORD;
	
	ABSOLUTE_EXECUTE1:BOOL;
	ABSOLUTE_POSITION1:LREAL:=180;
	ABSOLUTE_VELOCITY1:LREAL:=360;
	ABSOLUTE_ACCELERATION1:LREAL:=36000000;
	ABSOLUTE_DECELERATION1:LREAL:=36000000;
	ABSOLUTE_JERK1:LREAL:=360000000;
	ABSOLUTE_DIRECTION1:MC_DIRECTION;
	ABSOLUTE_BUFFERMODE1:MC_BUFFER_MODE;
	ABSOLUTE_DONE1:BOOL;
	ABSOLUTE_BUSY1:BOOL;
	ABSOLUTE_ACTIVE1:BOOL;
	ABSOLUTE_COMMANDABORTED1:BOOL;
	ABSOLUTE_ERROR1:BOOL;
	ABSOLUTE_ERRORID1:WORD;
	
	ABSOLUTE_EXECUTE2:BOOL;
	ABSOLUTE_POSITION2:LREAL:=360;
	ABSOLUTE_VELOCITY2:LREAL:=2880;
	ABSOLUTE_ACCELERATION2:LREAL:=36000000;
	ABSOLUTE_DECELERATION2:LREAL:=36000000;
	ABSOLUTE_JERK2:LREAL:=360000000;
	ABSOLUTE_DIRECTION2:MC_DIRECTION;
	ABSOLUTE_BUFFERMODE2:MC_BUFFER_MODE;
	ABSOLUTE_DONE2:BOOL;
	ABSOLUTE_BUSY2:BOOL;
	ABSOLUTE_ACTIVE2:BOOL;
	ABSOLUTE_COMMANDABORTED2:BOOL;
	ABSOLUTE_ERROR2:BOOL;
	ABSOLUTE_ERRORID2:WORD;
	

	a AT %MD0:DWORD;
	//a1 AT MW1 :WORD;;
	a2 AT %MW2:DWORD;
	a3 AT %MW4:DWORD;

	icounter:int;

END_VAR
</Single>
            <Single Name="LineInfoPersistence" Type="string">c651ac0b-a8a1-4305-8707-ce40a0b8c7cb_Decl_LineIds</Single>
