      <Single Name="Object" Type="{6f9dac99-8de1-4efc-8465-68ac443b7d08}" Method="IArchivable">
        <Single Name="SpecialFunc" Type="{0db3d7bb-cde0-4416-9a7b-ce49a0124323}">None</Single>
        <Single Name="Implementation" Type="{3b83b776-fb25-43b8-99f2-3c507c9143fc}" Method="IArchivable">
          <Single Name="TextDocument" Type="{f3878285-8e4f-490b-bb1b-9acbb7eb04db}" Method="IArchivable">
            <Single Name="TextBlobForSerialisation" Type="string">IF bAFOn AND iStep&gt;15 OR (TO_INT(iMotorTemp*0.1) &gt; Def.CoolFan_OnTemp)  THEN
	qbFan :=TRUE;
	iTimerCounter :=0;
ELSE
	iTimerCounter := iTimerCounter +1;
	IF TO_INT(iTimerCounter*0.01) &gt; Def.CoolFan_Toff THEN
		iTimerCounter := TO_UDINT(100*(Def.CoolFan_Toff+10));
		qbFan :=FALSE;
	END_IF
END_IF</Single>
            <Single Name="LineInfoPersistence" Type="string">7ca0c398-5276-422e-aa2d-2a7301eb509e_Impl_LineIds</Single>
