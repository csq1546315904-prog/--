            <Single Name="TextBlobForSerialisation" Type="string">FUNCTION_BLOCK FB_CrankSliderHeight
VAR_INPUT
    AngleDeg : REAL; (* 输入曲柄角度，单位° *)
END_VAR
VAR_OUTPUT
    HeightMM : REAL; (* 输出滑块高度，单位mm *)
END_VAR
VAR
    RR       : REAL := 16.0;   (* 曲柄半径mm *)
    L       : REAL := 220.0;  (* 连杆长度mm *)
    angleRad: REAL;
END_VAR
</Single>
