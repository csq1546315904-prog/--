            <Single Name="TextBlobForSerialisation" Type="string">PROGRAM DebugMode
VAR
	// ---------- HMI 输入信号 ----------
	bMCHomeExe          : BOOL;

	nStep               : INT;
	iCounter            : INT; 
	iDebugErr           : INT;
	iRetryCount         : INT;
	
	trHome              : R_TRIG;
    trMovePos           : R_TRIG;
    trMoveNeg           : R_TRIG;
	
	fbHome              : MC_Home;
END_VAR
</Single>
